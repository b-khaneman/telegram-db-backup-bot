# Telegram — never commit real .env
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here
ADMIN_IDS=123456789
BACKUP_CHAT_ID=

# Web panel
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_SECRET=change-me-to-a-long-random-secret
PANEL_PASSWORD=change-me-strong-password

# Webhook (leave PUBLIC_BASE_URL empty for polling)
PUBLIC_BASE_URL=
WEBHOOK_URL=
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=

# Paths
DATA_DIR=./data
BACKUP_DIR=./data/backups
KEEP_LOCAL_BACKUPS=5
TIMEZONE=Asia/Tehran
